subtitle = sprintf("YES(>%.0f)+YES(<%.0f), cost=%.3f", pm_upper, pm_lower, pm_cost),
x = "Settlement price S (USDT)",
y = "Payoff (USDT per share-equivalent)"
)
p_opt <- ggplot(grid, aes(S, opt)) +
geom_hline(yintercept = 0, linewidth = 0.3) +
geom_vline(xintercept = K, linewidth = 0.3, linetype = "dashed") +
geom_line() +
labs(
title = "Binance long straddle payoff vs option settlement price (S)",
subtitle = sprintf("Call+Put at K=%.0f, premium=%.2f (call)+%.2f (put)", K, prem_call, prem_put),
x = "Option settlement price S (USDT)",
y = "Payoff (USDT)"
)
p_combo <- ggplot(grid, aes(S, combo_same_time)) +
geom_hline(yintercept = 0, linewidth = 0.3) +
geom_vline(xintercept = c(pm_lower, K, pm_upper), linewidth = 0.25, linetype = "dotted") +
geom_line() +
labs(
title = "Combined payoff (assumes Polymarket and options settle on same S)",
subtitle = "Useful as a quick sanity-check; not truly 'risk-free' if settlement times differ",
x = "S (USDT)",
y = "Total payoff (USDT)"
)
# ----------------------------
# 4) 2D PLOTS (TWO DATE MODEL)
# ----------------------------
# Heatmap over (S7, ST) on a grid (deterministic view)
S7_vals <- seq(S_min, S_max, length.out = 241)
ST_vals <- seq(S_min, S_max, length.out = 241)
heat <- CJ(S7 = S7_vals, ST = ST_vals)
heat[, payoff := combined_payoff(S7, ST)]
p_heat <- ggplot(heat, aes(S7, ST)) +
geom_raster(aes(fill = payoff), interpolate = TRUE) +
geom_contour(aes(z = payoff), breaks = 0, color = "black", linewidth = 0.3) +
geom_vline(xintercept = c(pm_lower, pm_upper), linetype = "dashed", linewidth = 0.3) +
geom_hline(yintercept = K, linetype = "dashed", linewidth = 0.3) +
labs(
title = "Combined payoff heatmap when Polymarket resolves on S7 but options settle on ST",
subtitle = "Black contour = 0 payoff boundary",
x = "S7 (Polymarket settlement price)",
y = "ST (Option settlement price)",
fill = "Payoff"
)
# Risk view: for each S7, simulate ST distribution and compute expected and worst-tail payoff
simulate_conditional <- function(S7_vec,
mu_annual, sigma_annual, days_between,
n_mc = 20000, q = 0.01) {
T_years <- days_between / 365
out <- vector("list", length(S7_vec))
for (i in seq_along(S7_vec)) {
S7 <- S7_vec[i]
Z <- rnorm(n_mc)
ST <- S7 * exp((mu_annual - 0.5 * sigma_annual^2) * T_years + sigma_annual * sqrt(T_years) * Z)
pay <- combined_payoff(S7, ST)
out[[i]] <- data.table(
S7 = S7,
payoff_mean = mean(pay),
payoff_q = as.numeric(quantile(pay, probs = q)),
payoff_median = median(pay)
)
}
rbindlist(out)
}
p_risk <- NULL
risk_dt <- NULL
if (use_two_date_model) {
risk_dt <- simulate_conditional(
S7_vec = S7_vals,
mu_annual = mu_annual,
sigma_annual = sigma_annual,
days_between = days_between,
n_mc = n_mc,
q = quantile_q
)
p_risk <- ggplot(risk_dt, aes(S7)) +
geom_hline(yintercept = 0, linewidth = 0.3) +
geom_line(aes(y = payoff_mean), linewidth = 0.6) +
geom_line(aes(y = payoff_median), linetype = "dashed", linewidth = 0.5) +
geom_line(aes(y = payoff_q), linetype = "dotted", linewidth = 0.6) +
geom_vline(xintercept = c(pm_lower, pm_upper), linetype = "dashed", linewidth = 0.3) +
labs(
title = "Two-date risk view: payoff distribution over ST given S7",
subtitle = sprintf("GBM bridge: mu=%.2f, sigma=%.2f, T=%d days. Dotted=%.0f%% tail payoff.",
mu_annual, sigma_annual, days_between, 100*quantile_q),
x = "S7 (Polymarket settlement price, USDT)",
y = "Combined payoff stats (USDT)"
)
}
# ----------------------------
# 5) DISPLAY
# ----------------------------
if (ok) {
library(patchwork)
# Top row: 1D payoffs. Bottom: heatmap + risk view.
if (use_two_date_model) {
print((p_pm | p_opt | p_combo) / (p_heat | p_risk))
} else {
print(p_pm | p_opt | p_combo)
print(p_heat)
}
} else {
# No patchwork installed: print sequentially
print(p_pm)
print(p_opt)
print(p_combo)
print(p_heat)
if (!is.null(p_risk)) print(p_risk)
}
# ============================================================
# Payoff plots: Polymarket breakout digital + Binance straddle
# ============================================================
suppressPackageStartupMessages({
library(data.table)
library(ggplot2)
# Optional but nice for combining plots:
# install.packages("patchwork")
suppressWarnings(suppressMessages({
ok <- requireNamespace("patchwork", quietly = TRUE)
}))
})
# ----------------------------
# 1) USER INPUTS (EDIT THESE)
# ----------------------------
# Polymarket YES prices (in $ per share, 0..1)
p_yes_up   <- 0.34
p_no_up   <- 0.71
p_yes_down <- 0.52
p_no_down <- 0.53
# Your Polymarket strike levels
pm_upper <- 3200
pm_lower <- 3100
# Options: straddle at K=2950
K <- 3150
# Option premiums (in USDT per 1 ETH notional; set to Binance premium convention you use)
prem_call <- 120
prem_put  <- 110
# Contract size (Binance options are typically per 1 underlying unit; keep as 1 unless you want scaling)
contracts <- 1
# Fees (set to 0 if you ignore)
# Binance options fee formulas exist; you can approximate total fees with a flat number per contract if desired.
fee_trade   <- 0      # e.g., upfront transaction fee (USDT)
fee_exercise <- 0     # e.g., exercise/settlement fee (USDT)
# Grid for spot prices used in plots
S_min <- 2400
S_max <- 3400
n_grid <- 2001
# If options expire AFTER Jan 7: model ST distribution conditional on S7
# Use a simple GBM bridge: ST = S7 * exp((mu - 0.5*sigma^2)*T + sigma*sqrt(T)*Z)
use_two_date_model <- TRUE
mu_annual    <- 0.00     # drift (annualized)
sigma_annual <- 0.80     # vol (annualized)
days_between <- 7        # days from Jan 7 to option expiry (edit)
n_mc         <- 20000    # Monte Carlo paths per S7 (reduce if slow)
# Risk view for "arb": worst-case / quantile payoff over ST distribution
quantile_q <- 0.01       # 1% worst tail (set 0 for hard min if you brute-force grid instead)
set.seed(1)
# ----------------------------
# 2) PAYOFF FUNCTIONS
# ----------------------------
# Polymarket leg prices
pm_cost_strap <- p_no_up + p_yes_down
pm_payoff_strap <- function(S7) {
payout_no_up   <- as.numeric(S7 <= pm_upper)  # NO(>upper) pays if NOT above upper
payout_yes_down <- as.numeric(S7 >= pm_lower)  # YES(<lower) pays if below lower
(payout_no_up + payout_yes_down) - pm_cost
}
pm_cost_breakout <- p_yes_up + p_yes_down
pm_payoff_breakout <- function(S7) {
payout <- as.numeric(S7 > pm_upper | S7 < pm_lower)
payout - pm_cost
}
pm_cost <- pm_cost_strap
pm_payoff <- pm_payoff_strap
# Long straddle payoff at option settlement price ST:
# (max(ST-K,0) + max(K-ST,0)) - premiums - fees
opt_payoff <- function(ST) {
intrinsic <- pmax(ST - K, 0) + pmax(K - ST, 0)
contracts * intrinsic - contracts * (prem_call + prem_put) - fee_trade - fee_exercise
}
# Combined payoff:
# If same settlement time, use S = S7 = ST.
# If different dates, interpret as: pm resolves on S7, options on ST.
combined_payoff <- function(S7, ST) {
300*pm_payoff(S7) + opt_payoff(ST)
}
# ----------------------------
# 3) 1D PLOTS (SINGLE DATE)
# ----------------------------
grid <- data.table(S = seq(S_min, S_max, length.out = n_grid))
grid[, pm := pm_payoff(S)]
grid[, opt := opt_payoff(S)]
grid[, combo_same_time := pm + opt]
p_pm <- ggplot(grid, aes(S, pm)) +
geom_hline(yintercept = 0, linewidth = 0.3) +
geom_line() +
labs(
title = "Polymarket digital strangle payoff vs settlement price (S)",
subtitle = sprintf("YES(>%.0f)+YES(<%.0f), cost=%.3f", pm_upper, pm_lower, pm_cost),
x = "Settlement price S (USDT)",
y = "Payoff (USDT per share-equivalent)"
)
p_opt <- ggplot(grid, aes(S, opt)) +
geom_hline(yintercept = 0, linewidth = 0.3) +
geom_vline(xintercept = K, linewidth = 0.3, linetype = "dashed") +
geom_line() +
labs(
title = "Binance long straddle payoff vs option settlement price (S)",
subtitle = sprintf("Call+Put at K=%.0f, premium=%.2f (call)+%.2f (put)", K, prem_call, prem_put),
x = "Option settlement price S (USDT)",
y = "Payoff (USDT)"
)
p_combo <- ggplot(grid, aes(S, combo_same_time)) +
geom_hline(yintercept = 0, linewidth = 0.3) +
geom_vline(xintercept = c(pm_lower, K, pm_upper), linewidth = 0.25, linetype = "dotted") +
geom_line() +
labs(
title = "Combined payoff (assumes Polymarket and options settle on same S)",
subtitle = "Useful as a quick sanity-check; not truly 'risk-free' if settlement times differ",
x = "S (USDT)",
y = "Total payoff (USDT)"
)
# ----------------------------
# 4) 2D PLOTS (TWO DATE MODEL)
# ----------------------------
# Heatmap over (S7, ST) on a grid (deterministic view)
S7_vals <- seq(S_min, S_max, length.out = 241)
ST_vals <- seq(S_min, S_max, length.out = 241)
heat <- CJ(S7 = S7_vals, ST = ST_vals)
heat[, payoff := combined_payoff(S7, ST)]
p_heat <- ggplot(heat, aes(S7, ST)) +
geom_raster(aes(fill = payoff), interpolate = TRUE) +
geom_contour(aes(z = payoff), breaks = 0, color = "black", linewidth = 0.3) +
